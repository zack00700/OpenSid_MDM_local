# ═══════════════════════════════════════════════════
# O.S MDM V2 — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ═══════════════════════════════════════════════════

# OBLIGATOIRE en production : clé secrète pour les JWT (32+ caractères aléatoires)
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
MDM_SECRET=

# Origines CORS autorisées (séparées par des virgules)
MDM_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Clé de chiffrement des credentials DB (32 caractères)
# Si non défini, dérivée automatiquement de MDM_SECRET
MDM_ENCRYPT_KEY=

# Mode debug (true/false) — TOUJOURS false en production
MDM_DEBUG=false

# Moteur de base de données : sqlite (défaut) ou postgresql
MDM_DB_ENGINE=sqlite

# URL PostgreSQL (uniquement si MDM_DB_ENGINE=postgresql)
MDM_PG_URL=postgresql://user:password@localhost:5432/mdm

# Google SSO (optionnel)
GOOGLE_CLIENT_ID=

# Microsoft SSO (optionnel)
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
